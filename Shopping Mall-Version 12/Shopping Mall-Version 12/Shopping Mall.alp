					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return 
    goToEntrance.size() + 
    pedExit.size() + 
    areaDelay.size() + 
    cancelDelay.size() + 
    pedEnter.size();
]]></Body>
