    sourceWholeFoods.size() + 
    sourceMain.size() + 
    sourceAMC.size() + 
    sourceTarget1.size() + 
    sourceTarget2.size() + 
    upIKEA.size() + 
    upWholeFoods.size() + 
    upMain.size() + 
    upAMC.size() + 
    upTarget1.size() + 
    upTarget2.size() + 
