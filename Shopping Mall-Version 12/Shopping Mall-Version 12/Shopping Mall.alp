			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[void]]></ReturnType>
					<Id>1377525755608</Id>
					<Name><![CDATA[close]]></Name>
					<X>-300</X><Y>1180</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[isClosed = true;

for (AreaDelay d: WCs)
	d.cancelAll();
for (AreaDelay d: shops)
	d.cancelAll();
for (AreaDelay d: anchorShops)
	d.cancelAll();
eat.cancelAll();
skate.cancelAll();

sourceIKEA.set_rate(0);
sourceWholeFoods.set_rate(0);
sourceMain.set_rate(0);
sourceAMC.set_rate(0);
sourceTarget1.set_rate(0);
sourceTarget2.set_rate(0);
sourceElevator.set_rate(0);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[void]]></ReturnType>
					<Id>1394700648623</Id>
					<Name><![CDATA[generateTasks]]></Name>
					<X>-300</X><Y>1300</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[visitor]]></Name>
						<Type><![CDATA[Visitor]]></Type>
					</Parameter>
					<Body><![CDATA[int shopCount = uniform_discr(1, 10);
for (int i = 0; i < shopCount; i++)
{
	int shopIndex = uniform_discr(0, shopEntrances.size() - 1);
	visitor.tasks.add( new Task( SHOP, shopIndex ) );
}

int anchorShopCount = uniform_discr(1, 2);
for (int i = 0; i < anchorShopCount; i++)
{
	int shopIndex = uniform_discr(0, anchorShopEntrances.size() - 1);
	visitor.tasks.add( new Task( ANCHOR_SHOP, shopIndex ) );
}

if (randomTrue(foodProbability))
{
	visitor.tasks.add( new Task( FOOD, 0 ) );
}

if (randomTrue(wcProbability))
{
	int wcIndex = uniform_discr(0, wcEntrances.size() - 1);
	visitor.tasks.add( new Task( WC, wcIndex ) );
}
if (randomTrue(skateProbability))
{ 
	visitor.tasks.add( new Task( ICE, 0 ) );
}

Collections.shuffle(visitor.tasks, getEngine().getDefaultRandomGenerator());]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[void]]></ReturnType>
					<Id>1394804110700</Id>
					<Name><![CDATA[open]]></Name>
					<X>-300</X><Y>1210</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[isClosed = false;

sourceIKEA.set_rate( 100, PER_HOUR );
sourceWholeFoods.set_rate( 100, PER_HOUR );
sourceMain.set_rate( 100, PER_HOUR );
sourceAMC.set_rate( 100, PER_HOUR );
sourceTarget1.set_rate( 100, PER_HOUR );
sourceTarget2.set_rate( 100, PER_HOUR );
sourceElevator.set_rate( 100, PER_HOUR);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1488886020637</Id>
					<Name><![CDATA[navigate]]></Name>
					<X>-300</X><Y>1080</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[viewArea]]></Name>
						<Type><![CDATA[ViewArea]]></Type>
					</Parameter>
					<Body><![CDATA[selectedViewArea = viewArea;
viewArea.navigateTo();
groupMainMenu.setPos( viewArea.getX(), viewArea.getY() );]]></Body>
				</Function>
